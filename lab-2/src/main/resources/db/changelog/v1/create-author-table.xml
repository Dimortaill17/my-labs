<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="1" author="kruchkova">
        <createTable tableName="author">
            <column name="id" type="serial" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="birth_year" type="integer">
                <constraints nullable="false"/>
            </column>
        </createTable>


        <!-- Использую <sql>, так как это единственный способ добавить CHECK constraint в данной версии,
        иначе всё ломается... -->
        <sql>
            ALTER TABLE author ADD CONSTRAINT check_birth_year
                CHECK (birth_year BETWEEN 1800 AND 2010);
        </sql>

        <rollback>
            ALTER TABLE author DROP CONSTRAINT IF EXISTS check_birth_year;
        </rollback>
    </changeSet>

</databaseChangeLog>